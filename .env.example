# 국토교통부 실거래가 API 키
# 발급: https://www.data.go.kr → "아파트매매 실거래자료" 활용신청
MOLIT_API_KEY=your_molit_api_key_here

# Notion 통합 토큰
# 발급: https://www.notion.so/my-integrations → 새 통합 → 토큰 복사
NOTION_TOKEN=secret_xxxxxxxxxxxx

# Notion 부모 페이지 ID
# 방법: 공유할 Notion 페이지 열기 → 우상단 공유 → 링크 복사
#       https://notion.so/[페이지ID]?v=... 에서 [페이지ID] 부분
NOTION_PARENT_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 카카오 REST API 앱 키
# 발급: https://developers.kakao.com → 내 애플리케이션 → 앱 키 → REST API
KAKAO_APP_KEY=your_kakao_rest_api_key_here

# 카카오 리프레시 토큰 (setup_kakao.py 실행 후 여기에 입력)
KAKAO_REFRESH_TOKEN=your_kakao_refresh_token_here
